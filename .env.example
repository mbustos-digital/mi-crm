# ============================================================
# Variables de entorno requeridas por mi-crm
# ============================================================
#
# Copia este archivo como .env.local (gitignored) para desarrollo
# local con `vercel dev`. En producción, configurar en:
# Vercel → Settings → Environment Variables.
#
# ------------------------------------------------------------

# URL del Apps Script desplegado como Web App.
# Obtener desde: Apps Script editor → Implementar → Administrar
# implementaciones → URL de la Web App.
# Formato esperado:
#   https://script.google.com/macros/s/AKfycb..../exec
APPS_SCRIPT_URL=
